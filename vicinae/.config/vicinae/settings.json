// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "search_files_in_root": true,
   "font": {
      "normal": {
         "family": "JetBrainsMonoNL NFP"
      }
   },
   "theme": {
      "dark": {
         "name": "new-theme"
      }
   },
   "launcher_window": {
      "opacity": 0.8,
      "client_side_decorations": {
         "enabled": true
      }
   },
   "keybinds": {
      "toggle-action-panel": "control+B"
   },
   "providers": {
      "@ThatNerd/store.raycast.timers": {
         "preferences": {
            "ringContinuously": false,
            "selectedSound": "fluteRiff.wav"
         }
      },
      "@knoopx/store.vicinae.niri": {
         "entrypoints": {
            "power-off-monitors": {
               "enabled": false
            }
         }
      },
      "@mommertf/store.raycast.slack": {
         "entrypoints": {
            "open-unread-messages": {
               "enabled": false
            },
            "search": {
               "enabled": false
            },
            "search-emojis": {
               "enabled": false
            },
            "set-presence": {
               "enabled": false
            },
            "set-snooze": {
               "enabled": false
            },
            "set-status": {
               "enabled": false
            },
            "unread-messages": {
               "enabled": false
            }
         }
      },
      "@thomas/store.raycast.google-calendar": {
         "entrypoints": {
            "create-event": {
               "enabled": false
            },
            "create-quick-event": {
               "alias": "!q"
            },
            "list-calendars": {
               "enabled": true
            },
            "list-events": {
               "preferences": {
                  "openCommandJoinsMeeting": true
               }
            },
            "search-contacts": {
               "enabled": false
            }
         }
      },
      "applications": {
         "preferences": {
            "paths": [
               "/home/miltonr/.local/share/applications",
               "/home/miltonr/.local/share/flatpak/exports/share/applications",
               "/var/lib/flatpak/exports/share/applications",
               "/usr/share/applications",
               "/var/lib/snapd/desktop/applications"
            ]
         }
      },
      "calculator": {
         "preferences": {
            "backend": "soulver-core"
         }
      },
      "core": {
         "entrypoints": {
            "about": {
               "enabled": false
            },
            "documentation": {
               "enabled": false
            },
            "keybind-settings": {
               "enabled": false
            },
            "prune-memory": {
               "enabled": false
            },
            "settings": {
               "enabled": true
            },
            "sponsor": {
               "enabled": false
            }
         }
      },
      "developer": {
         "enabled": false
      },
      "system": {
         "entrypoints": {
            "run": {
               "enabled": false
            }
         }
      }
   }
}